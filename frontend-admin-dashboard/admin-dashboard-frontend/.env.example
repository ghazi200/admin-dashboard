# Optional: point API requests directly at the backend (bypasses CRA proxy).
# Use if you get 404 for /api/admin/notifications or /api/admin/messages/conversations.
# Leave unset to use relative /api/admin (proxy in setupProxy.js).
# REACT_APP_API_URL=http://localhost:5000

# Geographic Dashboard (Map): Google Maps JavaScript API key.
# Enable "Maps JavaScript API" in Google Cloud Console.
# REACT_APP_GOOGLE_MAPS_API_KEY=your_key_here
