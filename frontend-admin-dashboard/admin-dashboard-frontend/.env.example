# --- Required so the bundle never uses localhost in production ---
# Local dev: set these so the app talks to your machine. Production (Vercel): set these in Vercel → Settings → Environment Variables.

# Admin API (login, dashboard, reports, etc.). No trailing slash.
# Local:  REACT_APP_API_URL=http://localhost:5000
# Vercel: REACT_APP_API_URL=https://admin-dashboard-production-2596.up.railway.app
# REACT_APP_API_URL=

# Optional alias; used if REACT_APP_API_URL is not set.
# REACT_APP_ADMIN_API_URL=https://admin-dashboard-production-2596.up.railway.app/api/admin

# WebSocket Gateway (realtime). No trailing slash.
# Local:  REACT_APP_SOCKET_URL=http://localhost:4000  (or your gateway URL)
# Vercel: REACT_APP_WS_GATEWAY_URL=https://generous-manifestation-production-dbd9.up.railway.app
# REACT_APP_WS_GATEWAY_URL=

# Guard/AI backend (Inspections, etc.). Set in production.
# REACT_APP_GUARD_AI_URL=https://your-guard-api.up.railway.app

# Optional: Google Maps (Geographic Dashboard)
# REACT_APP_GOOGLE_MAPS_API_KEY=your_key_here
