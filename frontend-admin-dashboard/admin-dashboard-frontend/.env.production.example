# Production API URLs (replace with your deployed backend URLs)
# Required for build: set these in Vercel Environment Variables or in .env.production before building.

# Example: Railway backend (no trailing slash)
# REACT_APP_API_URL=https://admin-dashboard-production-2596.up.railway.app
# REACT_APP_ADMIN_API_URL=https://admin-dashboard-production-2596.up.railway.app/api/admin

# Admin backend base URL (no trailing slash). Used by api/axiosClient, guardMessaging, etc.
REACT_APP_API_URL=https://admin-api.yourdomain.com

# Admin API full base for login (optional; defaults from REACT_APP_API_URL in some paths)
REACT_APP_ADMIN_API_URL=https://admin-api.yourdomain.com/api/admin

# Realtime: WebSocket Gateway (optional; app defaults to generous-manifestation-production-dbd9.up.railway.app in production)
REACT_APP_WS_GATEWAY_URL=https://generous-manifestation-production-dbd9.up.railway.app

# Guard/AI backend for assistant and guard features
REACT_APP_GUARD_AI_URL=https://guard-api.yourdomain.com

# Optional: Google Maps (Geographic Dashboard)
# REACT_APP_GOOGLE_MAPS_API_KEY=your_key

# Optional: session timeout in minutes (default 30)
# REACT_APP_SESSION_TIMEOUT_MINUTES=30
