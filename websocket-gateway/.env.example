# WebSocket Gateway — copy to .env and fill in. Railway: use Variables tab with same names.

PORT=4001

# Same as Core API. Railway: ${{ Redis.REDIS_URL }} or your Redis service name.
REDIS_URL=redis://localhost:6379

# Same as Core API (JWT for socket auth).
JWT_SECRET=your-secret-at-least-16-characters-long

# Core API base URL (no trailing slash). Gateway calls this for conversation:join.
CORE_API_URL=https://admin-dashboard-production-2596.up.railway.app

# Allowed origins for Socket.IO (comma-separated). Your Vercel frontend URL(s).
CORS_ORIGINS=https://your-admin-dashboard.vercel.app
# Or: FRONTEND_URL=https://your-admin-dashboard.vercel.app
