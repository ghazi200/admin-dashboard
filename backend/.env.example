# Admin Dashboard Backend — copy to .env and fill in values.
# See docs/CONFIGURATION_AND_ENV.md and CORS.md for details.

# --- Required (production) ---
# 1. For production deployment set NODE_ENV=production (required for strict CORS, JWT check, etc.)
NODE_ENV=production
# Local: use the line below. Railway: paste DATABASE_URL from the next line into Railway → Variables.
DATABASE_URL=postgresql://user:password@localhost:5432/abe_guard
# DATABASE_URL=${{ Postgres.DATABASE_URL }}
JWT_SECRET=your-secret-at-least-16-characters-long

# --- Optional: DB (if not using DATABASE_URL) ---
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=abe_guard
# DB_USER=user
# DB_PASS=password

# --- Optional: Server ---
PORT=5000

# --- Realtime (WebSocket Gateway + Redis) ---
# Required for realtime events. Railway: REDIS_URL=${{ Redis.REDIS_URL }}
REDIS_URL=redis://localhost:6379

# --- Production CORS (required when frontend is on a different origin) ---
# Comma-separated list of allowed origins. Replace with your real deployed app URLs.
# Railway: use the line below (paste into Railway → Variables).
CORS_ORIGINS=https://admin-dashboard-frontend-flax.vercel.app,https://admin-dashboard-frontend-techworldstarzllcs-projects.vercel.app,https://frontend-guard-ui.vercel.app
# CORS_ORIGINS=https://admin.example.com,https://guard.example.com
# GUARD_APP_URL=https://guard.example.com
# ADMIN_APP_URL=https://admin.example.com

# --- Optional: Rate limiting ---
# RATE_LIMIT_MAX=500
# (default 500 per 15 min per IP; increase if AI Agent 24 / assistant hits "Too many requests")
# AUTH_RATE_LIMIT_MAX=10

# --- Optional: Debug / tuning ---
# DEBUG_STARTUP=true
# DEBUG_DASHBOARD=true
# STARTUP_TIMEOUT_MS=45000
# UNFILLED_SHIFT_CHECK_INTERVAL_MINUTES=5

# --- Optional: MFA (Twilio) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# --- Optional: Cron (shift reminders via HTTP) ---
# CRON_SECRET=random-secret-for-get-/api/cron/shift-reminders

# --- Optional: AI / external services ---
# OPENAI_API_KEY=
# RESET_DB=false
