# Production API URLs (replace with your deployed backend URLs)
# Set these in Vercel Environment Variables or in .env.production before building.

# Guard backend (abe-guard-ai) – no trailing slash
REACT_APP_GUARD_API_URL=https://guard-api.yourdomain.com

# Admin backend – no trailing slash
REACT_APP_ADMIN_API_URL=https://admin-api.yourdomain.com
