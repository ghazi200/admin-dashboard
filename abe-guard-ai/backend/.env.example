# Guard Backend (abe-guard-ai) — copy to .env and fill in values.
# Must use the same database (abe_guard) as the admin backend.
# See repo docs/CONFIGURATION_AND_ENV.md and CORS.md for details.

# --- Required (production) ---
# 1. For production deployment set NODE_ENV=production (required for strict CORS, JWT check, etc.)
NODE_ENV=production
DATABASE_URL=postgresql://user:password@localhost:5432/abe_guard
JWT_SECRET=your-secret-at-least-16-characters-long

# --- Optional: Server ---
PORT=4000

# --- Production CORS (required when frontend is on a different origin) ---
# Replace with your real deployed app URLs.
CORS_ORIGINS=https://guard.example.com,https://admin.example.com
# FRONTEND_URL=https://guard.example.com
# ADMIN_DASHBOARD_URL=https://admin.example.com
# GUARD_APP_URL=https://guard.mycompany.com

# --- Optional: Rate limiting ---
# RATE_LIMIT_MAX=200
# AUTH_RATE_LIMIT_MAX=10

# --- Optional: AI (policy, payroll, etc.) ---
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# DEEPSEEK_MODEL=deepseek-chat

# --- Optional: Alerts / maps ---
# GOOGLE_MAPS_API_KEY=
# WEATHER_API_KEY=
# OPENWEATHER_API_KEY=

# --- Optional: Email / SMS ---
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
