# Guard Backend (abe-guard-ai) — copy to .env and fill in values.
# Must use the same database (abe_guard) as the admin backend.
# See repo docs/CONFIGURATION_AND_ENV.md and CORS.md for details.

# --- Required (production) ---
# 1. For production deployment set NODE_ENV=production (required for strict CORS, JWT check, etc.)
NODE_ENV=production
# Local: use the line below. Railway: paste DATABASE_URL from the next line into Railway → Variables.
DATABASE_URL=postgresql://user:password@localhost:5432/abe_guard
# DATABASE_URL=${{ Postgres.DATABASE_URL }}
JWT_SECRET=your-secret-at-least-16-characters-long

# --- Optional: Server ---
PORT=4000

# --- Production CORS (required when frontend is on a different origin) ---
# Railway: use the line below (paste into Railway → Variables).
CORS_ORIGINS=https://admin-dashboard-frontend-flax.vercel.app,https://admin-dashboard-frontend-techworldstarzllcs-projects.vercel.app,https://frontend-guard-ui.vercel.app
# CORS_ORIGINS=https://guard.example.com,https://admin.example.com
# FRONTEND_URL=https://guard.example.com
# ADMIN_DASHBOARD_URL=https://admin.example.com
# GUARD_APP_URL=https://guard.mycompany.com

# --- Optional: Admin Schedule live refresh (WebSocket Gateway) ---
# Same REDIS_URL as websocket-gateway + admin backend. When set, callout_started / shift_filled /
# callout_response are published so the admin Schedule page refetches immediately in production.
# REDIS_URL=redis://default:password@redis.railway.internal:6379
# REDIS_PRIVATE_URL=...   # Railway internal, if you use it instead

# --- Optional: Rate limiting ---
# RATE_LIMIT_MAX=200
# AUTH_RATE_LIMIT_MAX=10

# --- Optional: AI (policy, payroll, etc.) ---
# You can also put OPENAI_API_KEY in the monorepo root .env (admin-dashboard/.env); it is loaded
# after this file with lower priority (see src/loadEnv.js).
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# DEEPSEEK_MODEL=deepseek-chat

# --- Optional: Alerts / maps ---
# GOOGLE_MAPS_API_KEY=
# WEATHER_API_KEY=
# OPENWEATHER_API_KEY=

# --- Optional: Email / SMS / voice callouts ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="ABE Security <no-reply@example.com>"
#
# Twilio (SMS + outbound call audio). Trial accounts can only message verified numbers.
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=
# Option A — Messaging Service (recommended; matches Twilio Console curl with MessagingServiceSid):
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxx
# Option B — single sender number:
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
#
# Public HTTPS URL of THIS service (Railway domain) so Twilio can fetch TwiML for calls:
# PUBLIC_BASE_URL=https://your-abe-guard-ai.up.railway.app
#
# Voice calls cost money — off by default:
# CALLOUT_ENABLE_VOICE_CALL=true
#
# Cap SMS/email/call per callout (trial ~50/day; avoid blasting every active guard at once).
# 0 or unset = no limit. Example: top 10 ranked guards only get Twilio + DB callout rows.
# CALLOUT_MAX_GUARDS_NOTIFY=10
